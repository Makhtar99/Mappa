<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Mappa.Ui.MainWindow"
        Width="1120" Height="740"
        Title="Mappa — Moniteur de routage ArtNet (Personne A)">

  <DockPanel>

    <!-- Barre de statut (bas) : partagee par les deux onglets -->
    <Border DockPanel.Dock="Bottom" Padding="8" Background="#141417">
      <TextBlock x:Name="StatusText" Text="Prêt — charge une config puis Start." Foreground="#bbb"/>
    </Border>

    <!-- ================= ONGLETS EN HAUT ================= -->
    <TabControl>

      <!-- ============ ONGLET 1 : VISUALISEUR ============ -->
      <TabItem Header="Visualiseur">
        <DockPanel>

          <!-- Panneau de controle (gauche) -->
          <Border DockPanel.Dock="Left" Width="310" Padding="14" Background="#1b1b1f">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="10">

                <TextBlock Text="CONFIGURATION" FontWeight="Bold" Foreground="#8ab4f8"/>
                <TextBox x:Name="ConfigPath" Watermark="chemin d'une config .json"/>
                <Button x:Name="LoadBtn" Content="Charger un .json"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                <Button x:Name="ImportXlsxBtn" Content="Importer un .xlsx (eHuB)…"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

                <Border Height="1" Background="#333" Margin="0,4"/>

                <TextBlock Text="ROUTAGE" FontWeight="Bold" Foreground="#8ab4f8"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button x:Name="StartBtn" Content="▶ Start" Width="130"
                          HorizontalContentAlignment="Center"/>
                  <Button x:Name="StopBtn" Content="■ Stop" Width="130"
                          HorizontalContentAlignment="Center"/>
                </StackPanel>
                <CheckBox x:Name="FakerChk" Content="Faker (démo arc-en-ciel)" IsChecked="True"/>
                <CheckBox x:Name="EhubChk" Content="Recevoir eHuB (réseau)"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Port eHuB" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="EhubPortBox" Text="8765" Width="80"/>
                </StackPanel>
                <CheckBox x:Name="SendChk" Content="Émettre en ArtNet (UDP réel)"/>

                <Border Height="1" Background="#333" Margin="0,4"/>

                <TextBlock Text="STATISTIQUES" FontWeight="Bold" Foreground="#8ab4f8"/>
                <TextBlock x:Name="StatsText" Text="—"
                           FontFamily="Consolas, Cascadia Mono, monospace"
                           Foreground="#d0d0d0"/>

                <Border Height="1" Background="#333" Margin="0,4"/>

                <TextBlock Text="Visualiseur DMX : 1 ligne = 1 univers, 1 case = 1 LED (RVB), avant encapsulation ArtNet."
                           TextWrapping="Wrap" Foreground="#888" FontSize="11"/>

              </StackPanel>
            </ScrollViewer>
          </Border>

          <!-- Visualiseur DMX (centre) -->
          <ScrollViewer Background="#0a0a0c"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <Image x:Name="DmxImage" Stretch="None"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"/>
          </ScrollViewer>

        </DockPanel>
      </TabItem>

      <!-- ============ ONGLET 2 : DEBOGAGE ============ -->
      <TabItem Header="Débogage">
        <DockPanel Background="#141418">
          <TextBlock DockPanel.Dock="Top" Margin="14,10,14,0"
                     Text="Lis les nœuds de GAUCHE à DROITE : le 1er moniteur faux = l'étape qui bugue."
                     TextWrapping="Wrap" Foreground="#888" FontSize="11"/>
          <ScrollViewer x:Name="DebugScrollViewer" HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="14" VerticalAlignment="Top">

            <!-- ═══ Simulation UDP (source de test = faux Unity) ═══ -->
            <Border Background="#1d1d24" BorderBrush="#3a3a44" BorderThickness="1"
                    CornerRadius="6" Padding="8" Width="250" VerticalAlignment="Top">
              <StackPanel Spacing="6">
                <TextBlock Text="Simulation UDP (faux Unity)" FontWeight="Bold" Foreground="#e0e0e0"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Port" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="SimPortBox" Text="8765" Width="70"/>
                  <TextBlock Text="Univers" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="SimUniverseBox" Text="1" Width="48"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Start" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="SimStartBox" Text="1" Width="48"/>
                  <TextBlock Text="End" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="SimEndBox" Text="10" Width="48"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="R,V,B" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="SimColorBox" Text="255,255,0" Width="120"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Motif" VerticalAlignment="Center" Foreground="#bbb"/>
                  <ComboBox x:Name="FakerMotifBox" SelectedIndex="0" Width="150">
                    <ComboBoxItem>Couleur unie</ComboBoxItem>
                    <ComboBoxItem>Chenillard</ComboBoxItem>
                    <ComboBoxItem>Arc-en-ciel</ComboBoxItem>
                    <ComboBoxItem>Clignotement</ComboBoxItem>
                    <ComboBoxItem>Tout blanc</ComboBoxItem>
                  </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Delay ms" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="FakerDelayBox" Text="120" Width="70"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button x:Name="SimulateUnityBtn" Content="Envoyer 1 frame"/>
                  <Button x:Name="AnimateBtn" Content="▶ Animer"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Burst" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="FakerBurstBox" Text="10" Width="52"/>
                  <Button x:Name="BurstBtn" Content="Envoyer N frames"/>
                </StackPanel>
                <TextBlock Text="1 frame = image figée. « Animer » = envoi continu (le chenillard / l'arc-en-ciel bougent)."
                           TextWrapping="Wrap" Foreground="#888" FontSize="11"/>
              </StackPanel>
            </Border>
            <TextBlock Text="→" VerticalAlignment="Center" Foreground="#666" FontSize="18"/>

            <!-- ═══ Étape ① : Réception UDP ═══ -->
            <Border Background="#202028" BorderBrush="#3a3a44" BorderThickness="1"
                    CornerRadius="6" Padding="8" Width="250" VerticalAlignment="Top">
              <StackPanel Spacing="6">
                <TextBlock Text="① Réception UDP" FontWeight="Bold" Foreground="#e0e0e0"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Port" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="InPortBox" Text="8765" Width="70"/>
                  <TextBlock Text="Univers" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="UniverseFilterBox" Watermark="tous" Width="56"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button x:Name="ListenBtn" Content="▶ Écouter"/>
                  <TextBlock x:Name="RxInfo" Text="—" VerticalAlignment="Center"
                             Foreground="#888" FontSize="11"/>
                </StackPanel>
              </StackPanel>
            </Border>
            <TextBlock Text="→" VerticalAlignment="Center" Foreground="#666" FontSize="18"/>

            <!-- ═══ Étape ② : Détail paquet ═══ -->
            <Border Background="#202028" BorderBrush="#3a3a44" BorderThickness="1"
                    CornerRadius="6" Padding="8" Width="250" VerticalAlignment="Top">
              <StackPanel Spacing="6">
                <TextBlock Text="② Détail du paquet" FontWeight="Bold" Foreground="#e0e0e0"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Start" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="FilterStartBox" Text="1" Width="48"/>
                  <TextBlock Text="End" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="FilterEndBox" Text="10" Width="48"/>
                </StackPanel>
                <TextBlock Text="Start/End = plage d'IDs de l'univers sélectionné à inspecter."
                           Foreground="#888" FontSize="11"/>
                <Border Background="#000" Padding="4" CornerRadius="3">
                  <WrapPanel x:Name="LedMonitor"/>
                </Border>
              </StackPanel>
            </Border>
            <TextBlock Text="→" VerticalAlignment="Center" Foreground="#666" FontSize="18"/>

            <!-- ═══ Étape ③ : Emitter Group → DMX ═══ -->
            <Border Background="#202028" BorderBrush="#3a3a44" BorderThickness="1"
                    CornerRadius="6" Padding="8" Width="250" VerticalAlignment="Top">
              <StackPanel Spacing="6">
                <TextBlock Text="③ Emitter Group → DMX" FontWeight="Bold" Foreground="#e0e0e0"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Format" VerticalAlignment="Center" Foreground="#bbb"/>
                  <ComboBox x:Name="FormatBox" SelectedIndex="0" Width="120">
                    <ComboBoxItem>RGB</ComboBoxItem>
                    <ComboBoxItem>GRB</ComboBoxItem>
                    <ComboBoxItem>Mono (R)</ComboBoxItem>
                  </ComboBox>
                </StackPanel>
                <TextBlock Text="moniteur : nb de carrés = type de LED (RGB=3, Mono=1)"
                           Foreground="#888" FontSize="11"/>
                <Border Background="#000" Padding="4" CornerRadius="3">
                  <WrapPanel x:Name="DmxMonitor"/>
                </Border>
              </StackPanel>
            </Border>
            <TextBlock Text="→" VerticalAlignment="Center" Foreground="#666" FontSize="18"/>

            <!-- ═══ Étape ④ : DMX → ArtNet ═══ -->
            <Border Background="#202028" BorderBrush="#3a3a44" BorderThickness="1"
                    CornerRadius="6" Padding="8" Width="250" VerticalAlignment="Top">
              <StackPanel Spacing="6">
                <TextBlock Text="④ DMX → ArtNet" FontWeight="Bold" Foreground="#e0e0e0"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Univers" VerticalAlignment="Center" Foreground="#bbb" Width="52"/>
                  <TextBox x:Name="TestUniverseBox" Text="0" Width="60"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="IP" VerticalAlignment="Center" Foreground="#bbb" Width="52"/>
                  <TextBox x:Name="TestIpBox" Watermark="ex : 10.0.0.1" Width="150"/>
                </StackPanel>
                <TextBlock x:Name="Node4Hint" Text="" Foreground="#8ab4f8" FontSize="11"/>
                <TextBlock Text="IP pré-remplie depuis la config (univers → contrôleur), modifiable. La trame part vers cette IP."
                           TextWrapping="Wrap" Foreground="#888" FontSize="11"/>
                <Border Background="#000" Padding="4" CornerRadius="3">
                  <WrapPanel x:Name="ArtNetMonitor" Width="224"/>
                </Border>
                <Button x:Name="SendFrameBtn" Content="Envoyer la trame"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button x:Name="TestWhiteBtn" Content="WHITE" Width="60"/>
                  <Button x:Name="TestBlackBtn" Content="BLACK" Width="60"/>
                  <Button x:Name="StreamBtn" Content="▶ Continu"/>
                </StackPanel>
              </StackPanel>
            </Border>
            <TextBlock Text="→" VerticalAlignment="Center" Foreground="#666" FontSize="18"/>

            <!-- ═══ ⑤ Moniteur ArtNet (réseau) ═══ -->
            <Border Background="#202028" BorderBrush="#3a3a44" BorderThickness="1"
                    CornerRadius="6" Padding="8" Width="250" VerticalAlignment="Top">
              <StackPanel Spacing="6">
                <TextBlock Text="⑤ Moniteur ArtNet (réseau)" FontWeight="Bold" Foreground="#e0e0e0"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Port" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="ArtPortBox" Text="6454" Width="70"/>
                  <Button x:Name="ArtListenBtn" Content="▶ Écouter"/>
                </StackPanel>
                <TextBlock x:Name="ArtRxInfo" Text="—" TextWrapping="Wrap"
                           Foreground="#888" FontSize="11"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="Voir univers" VerticalAlignment="Center" Foreground="#bbb"/>
                  <TextBox x:Name="ArtViewUniverseBox" Text="0" Width="60"/>
                </StackPanel>
                <TextBlock Text="DMX reçu sur le réseau pour cet univers :"
                           TextWrapping="Wrap" Foreground="#888" FontSize="11"/>
                <Border Background="#000" Padding="4" CornerRadius="3">
                  <WrapPanel x:Name="ArtDmxMonitor" Width="224"/>
                </Border>
              </StackPanel>
            </Border>

            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </TabItem>

    </TabControl>

  </DockPanel>
</Window>
